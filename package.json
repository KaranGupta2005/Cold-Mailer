{
  "name": "mass-mailer-pro",
  "version": "1.0.0",
  "description": "Professional mass email sender with React frontend",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "server": "node server/index.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npm run build && cd ..",
    "start": "node server/index.js"
  },
  "keywords": [
    "email",
    "mailer",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "multer": "^2.0.0-rc.4",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
